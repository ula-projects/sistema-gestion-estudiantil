generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/**
 * =========================
 * ENUMS
 * =========================
 */

enum Role {
  STUDENT
  PROFESSOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  WITHDRAWN
  SUSPENDED
}

enum CurriculumStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RequirementType {
  REQUIRED
  ELECTIVE
}

enum AcademicPeriod {
  FIRST
  SECOND
  SUMMER
}

enum TermStatus {
  PLANNED
  ACTIVE
  CLOSED
}

enum EnrollmentPeriodStatus {
  SCHEDULED
  OPEN
  CLOSED
  CANCELLED
}

enum SectionStatus {
  PLANNED
  OPEN
  CLOSED
  CANCELLED
}

enum EnrollmentStatus {
  PENDING
  ENROLLED
  DROPPED
  COMPLETED
  FAILED
}

enum GradeStatus {
  PENDING
  PASSED
  FAILED
  WITHDRAWN
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Modality {
  IN_PERSON
  ONLINE
  HYBRID
}

/**
 * =========================
 * AUTH / USERS
 * NextAuth/Auth.js con Credentials + JWT
 * =========================
 */

model User {
  id              String     @id @default(cuid())
  name            String?
  email           String     @unique
  institutionalId String     @unique
  passwordHash    String

  role            Role       @default(STUDENT)
  status          UserStatus @default(ACTIVE)

  mustChangePassword Boolean @default(true)
  lastLoginAt        DateTime?

  studentProfile   StudentProfile?
  professorProfile ProfessorProfile?
  adminProfile     AdminProfile?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([role])
  @@index([status])
}



/**
 * =========================
 * ESTRUCTURA ACADÉMICA
 * Facultad -> Carrera -> Opción -> Pensum
 * =========================
 */

model Faculty {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?

  schools     School[]
  departments Department[]
  classrooms  Classroom[]

  enrollmentPeriods EnrollmentPeriod[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model School {
  id          String  @id @default(cuid())
  facultyId   String
  code        String
  name        String
  description String?

  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Restrict)

  careers Career[]

  enrollmentPeriods EnrollmentPeriod[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([facultyId, code])
  @@index([facultyId])
}

model Department {
  id          String  @id @default(cuid())
  facultyId   String
  code        String
  name        String
  description String?

  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Restrict)

  subjects   Subject[]
  professors ProfessorProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([facultyId, code])
  @@index([facultyId])
}

model Career {
  id          String  @id @default(cuid())
  schoolId    String
  code        String
  name        String
  description String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  options CareerOption[]

  enrollmentPeriods EnrollmentPeriod[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, code])
  @@index([schoolId])
}

model CareerOption {
  id          String  @id @default(cuid())
  careerId    String
  code        String
  name        String
  description String?

  career      Career @relation(fields: [careerId], references: [id], onDelete: Restrict)
  curricula   Curriculum[]
  students    StudentProfile[]

  enrollmentPeriods EnrollmentPeriod[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([careerId, code])
  @@index([careerId])
}

model Curriculum {
  id                 String           @id @default(cuid())
  careerOptionId      String
  code               String
  name               String
  version            Int
  status             CurriculumStatus @default(DRAFT)
  totalCredits        Int?

  effectiveFromTermId String?

  careerOption CareerOption @relation(fields: [careerOptionId], references: [id], onDelete: Restrict)

  effectiveFromTerm AcademicTerm? @relation( "CurriculumEffectiveTerm", fields: [effectiveFromTermId], references: [id], onDelete: SetNull)

  subjects       CurriculumSubject[]
  electiveGroups ElectiveGroup[]
  students       StudentProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([careerOptionId, version])
  @@unique([careerOptionId, code])
  @@index([status])
}

/**
 * Materias base.
 * Ejemplo:
 * MAT101 - Matemática I
 * INF201 - Programación II
 */
model Subject {
  id           String  @id @default(cuid())
  departmentId String

  code         String  @unique
  name         String
  description  String?
  credits      Int
  hoursPerWeek Int?
  isActive     Boolean @default(true)

  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  curriculumSubjects CurriculumSubject[]
  sections           CourseSection[]

  prerequisites SubjectPrerequisite[] @relation("SubjectPrerequisites")
  requiredFor   SubjectPrerequisite[] @relation("PrerequisiteSubjects")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([isActive])
}

/**
 * Relación de prerrequisitos.
 * Ejemplo:
 * Programación II requiere Programación I.
 */
model SubjectPrerequisite {
  subjectId      String
  prerequisiteId String

  subject Subject @relation( "SubjectPrerequisites", fields: [subjectId], references: [id], onDelete: Cascade)

  prerequisite Subject @relation( "PrerequisiteSubjects", fields: [prerequisiteId], references: [id], onDelete: Restrict)

  @@id([subjectId, prerequisiteId])
}

/**
 * Materias dentro de un pensum.
 * Aquí defines si una materia es obligatoria o electiva,
 * en qué semestre sugerido va y con cuántos créditos cuenta dentro del pensum.
 */
model CurriculumSubject {
  id              String          @id @default(cuid())
  curriculumId    String
  subjectId       String
  electiveGroupId String?

  requirementType RequirementType
  semesterNumber  Int
  credits         Int
  minPassingGrade Decimal         @default(10.00) @db.Decimal(5, 2)

  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  subject    Subject    @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  electiveGroup ElectiveGroup? @relation( fields: [electiveGroupId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([curriculumId, subjectId])
  @@index([curriculumId, semesterNumber])
  @@index([subjectId])
}

/**
 * Grupo de materias electivas.
 * Ejemplo:
 * "Electivas Profesionales": el estudiante debe aprobar 2 materias o 6 créditos.
 */
model ElectiveGroup {
  id               String @id @default(cuid())
  curriculumId      String
  name             String
  semesterNumber   Int
  requiredCredits  Int?
  requiredSubjects Int?

  curriculum Curriculum          @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  subjects   CurriculumSubject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([curriculumId])
}

/**
 * =========================
 * PERFILES POR ROL
 * =========================
 */

model StudentProfile {
  id                    String        @id @default(cuid())
  userId                String        @unique
  studentCode           String        @unique
  nationalId            String?       @unique

  birthDate             DateTime?
  phone                 String?
  address               String?

  admissionTermId        String?
  currentCareerOptionId  String
  curriculumId           String

  status                StudentStatus @default(ACTIVE)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  admissionTerm AcademicTerm? @relation( "StudentAdmissionTerm", fields: [admissionTermId], references: [id], onDelete: SetNull)

  currentCareerOption CareerOption @relation( fields: [currentCareerOptionId], references: [id], onDelete: Restrict)

  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Restrict)

  enrollments SectionEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([currentCareerOptionId])
  @@index([curriculumId])
  @@index([status])
}

model ProfessorProfile {
  id           String  @id @default(cuid())
  userId       String  @unique
  employeeCode String  @unique
  departmentId String?

  phone        String?
  academicTitle String?
  office       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  department Department? @relation( fields: [departmentId], references: [id], onDelete: SetNull)

  sections       CourseSection[]
  gradesUploaded StudentGrade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
}

model AdminProfile {
  id           String  @id @default(cuid())
  userId       String  @unique
  employeeCode String? @unique
  position     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * =========================
 * SEMESTRES / PERIODOS
 * =========================
 */

model AcademicTerm {
  id        String         @id @default(cuid())
  code      String         @unique // Ejemplo: "2026-1"
  year      Int
  period    AcademicPeriod
  startsAt  DateTime
  endsAt    DateTime
  status    TermStatus     @default(PLANNED)

  enrollmentPeriods EnrollmentPeriod[]
  sections          CourseSection[]

  admittedStudents StudentProfile[] @relation("StudentAdmissionTerm")
  curriculaEffective Curriculum[]   @relation("CurriculumEffectiveTerm")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, period])
  @@index([status])
}

/**
 * Proceso de inscripción.
 * Sirve para activar o cerrar la inscripción antes de cada semestre.
 */
model EnrollmentPeriod {
  id        String                 @id @default(cuid())
  termId    String
  name      String
  startsAt  DateTime
  endsAt    DateTime
  status    EnrollmentPeriodStatus @default(SCHEDULED)

  facultyId      String?
  schoolId       String?
  careerId       String?
  careerOptionId String?

  term AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  faculty Faculty? @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  school  School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  career  Career?  @relation(fields: [careerId], references: [id], onDelete: SetNull)

  careerOption CareerOption? @relation( fields: [careerOptionId], references: [id], onDelete: SetNull)

  enrollments SectionEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([termId])
  @@index([status])
  @@index([facultyId])
  @@index([schoolId])
  @@index([careerId])
  @@index([careerOptionId])
}

/**
 * =========================
 * OFERTA ACADÉMICA / SECCIONES / HORARIOS
 * =========================
 */

model CourseSection {
  id          String        @id @default(cuid())
  termId      String
  subjectId   String
  professorId String?

  sectionCode String        // Ejemplo: "A", "B", "01"
  capacity    Int
  modality    Modality      @default(IN_PERSON)
  status      SectionStatus @default(PLANNED)

  gradesSubmittedAt DateTime?
  gradesLockedAt    DateTime?

  term      AcademicTerm      @relation(fields: [termId], references: [id], onDelete: Cascade)
  subject   Subject           @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  professor ProfessorProfile? @relation(fields: [professorId], references: [id], onDelete: SetNull)

  schedules   SectionSchedule[]
  enrollments SectionEnrollment[]
  gradeItems  GradeItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([termId, subjectId, sectionCode])
  @@index([termId])
  @@index([subjectId])
  @@index([professorId])
  @@index([status])
}

model Classroom {
  id        String  @id @default(cuid())
  facultyId String

  code      String
  building  String?
  room      String?
  capacity  Int?

  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Restrict)

  schedules SectionSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([facultyId, code])
  @@index([facultyId])
}

/**
 * Horario de una sección.
 * startMinute y endMinute representan minutos desde las 00:00.
 * Ejemplo:
 * 08:00 = 480
 * 09:30 = 570
 */
model SectionSchedule {
  id          String    @id @default(cuid())
  sectionId   String
  classroomId String?

  dayOfWeek   DayOfWeek
  startMinute Int
  endMinute   Int

  section CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  classroom Classroom?  @relation(fields: [classroomId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId])
  @@index([classroomId])
  @@index([dayOfWeek])
}

/**
 * =========================
 * INSCRIPCIONES Y NOTAS
 * =========================
 */

/**
 * Inscripción de un estudiante en una sección.
 * Esta tabla es clave para:
 * - historial académico
 * - materias vistas
 * - materias aprobadas
 * - promedio
 * - estudiantes por sección
 * - notas finales
 */
model SectionEnrollment {
  id                 String           @id @default(cuid())
  studentId           String
  sectionId           String
  enrollmentPeriodId  String?

  status              EnrollmentStatus @default(PENDING)

  enrolledAt          DateTime         @default(now())
  droppedAt           DateTime?

  finalGrade          Decimal?         @db.Decimal(5, 2)
  gradeStatus         GradeStatus?
  approvedAt          DateTime?

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section CourseSection  @relation(fields: [sectionId], references: [id], onDelete: Restrict)

  enrollmentPeriod EnrollmentPeriod? @relation( fields: [enrollmentPeriodId], references: [id], onDelete: SetNull)

  grades StudentGrade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sectionId])
  @@index([studentId])
  @@index([sectionId])
  @@index([status])
  @@index([gradeStatus])
}

/**
 * Ítems de evaluación dentro de una sección.
 * Ejemplo:
 * Parcial 1 - 25%
 * Proyecto - 30%
 * Examen final - 45%
 */
model GradeItem {
  id        String   @id @default(cuid())
  sectionId String
  name      String
  weight    Decimal  @db.Decimal(5, 2) // porcentaje: 25.00, 30.00, etc.
  maxScore  Decimal  @default(20.00) @db.Decimal(5, 2)
  dueDate   DateTime?

  section CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  grades  StudentGrade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId])
}

/**
 * Nota de un estudiante en un ítem de evaluación.
 */
model StudentGrade {
  id                  String   @id @default(cuid())
  enrollmentId         String
  gradeItemId          String
  score               Decimal  @db.Decimal(5, 2)

  gradedAt             DateTime @default(now())
  gradedByProfessorId  String?

  enrollment SectionEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  gradeItem  GradeItem         @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)

  gradedBy ProfessorProfile? @relation( fields: [gradedByProfessorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([enrollmentId, gradeItemId])
  @@index([gradedByProfessorId])
}